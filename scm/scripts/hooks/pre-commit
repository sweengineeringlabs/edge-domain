#!/usr/bin/env bash
set -euo pipefail
REPO_ROOT="$(git rev-parse --show-toplevel)"
SCM_DIR="$REPO_ROOT/scm"
echo "pre-commit ── $(basename $REPO_ROOT) ──"
cd "$SCM_DIR"
echo "  1/4 fmt..."
cargo fmt --all -- --check
echo "  2/4 clippy..."
cargo clippy --workspace --all-targets -- -D warnings
echo "  3/4 arch audit..."
# Rules 227 and 228 are waived (run checks 1-226 only). They were introduced by
# a mid-flight struct-engine rebuild and are defective:
#   - 227 is logically unsatisfiable for shared-kernel types: any type used by
#     2+ themes (e.g. EventEnvelope) trips it from every single-theme home, and
#     the neutral flat api/types/ home is forbidden by rule 208.
#   - 228 over-reaches: it flags legitimately-used concrete impls, value types,
#     and even traits (EventSource is used by the EventReceiver struct).
# Tracked in sweengineeringlabs/edge-domain#9 (228) and #10 (227). Drop the
# --checks filter once struct-engine corrects these rules.
arch audit --rs --checks 1-226
echo "  4/4 cargo audit..."
cargo audit --deny unsound --deny yanked
echo "pre-commit: all checks passed."
